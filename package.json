{
  "name": "erfana",
  "version": "0.16.0",
  "description": "Project IDE with Markdown, Project Tree, and Terminal",
  "main": "./out/main/index.js",
  "author": "Qodeca sp. z o.o.",
  "license": "GPL-3.0-only",
  "private": true,
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint . --ext .js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "test": "vitest --run --workspace vitest.workspace.ts",
    "test:watch": "vitest --workspace vitest.workspace.ts --watch",
    "test:ci": "vitest --run --workspace vitest.workspace.ts --reporter=dot",
    "test:main": "vitest --run --config vitest.main.ts",
    "test:preload": "vitest --run --config vitest.preload.ts",
    "test:renderer": "vitest --run --config vitest.renderer.ts",
    "test:cov": "node scripts/test-cov.mjs",
    "check:headers": "node scripts/check-spdx-headers.mjs",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "postinstall": "patch-package && electron-builder install-app-deps",
    "prebuild": "node scripts/prebuild.mjs",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "build:mac:test": "npm run build && ERFANA_TEST_BUILD=true electron-builder --mac -c.directories.output=release/test/${npm_package_version}",
    "test:e2e": "electron-vite build && playwright test --project=electron",
    "test:e2e:no-build": "playwright test --project=electron",
    "test:e2e:headed": "electron-vite build && playwright test --project=electron --headed",
    "test:e2e:visual": "electron-vite build && playwright test --project=visual",
    "test:e2e:update-screenshots": "electron-vite build && playwright test --project=visual --update-snapshots"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@llamaindex/liteparse": "1.4.1",
    "@noble/ed25519": "2.1.0",
    "@turbodocx/html-to-docx": "^1.18.1",
    "async-mutex": "^0.5.0",
    "chokidar": "3.6.0",
    "electron-log": "^5.4.4",
    "electron-store": "^11.0.2",
    "extract-zip": "2.0.1",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "fluent-ffmpeg": "^2.1.3",
    "isomorphic-git": "^1.35.1",
    "music-metadata": "^11.11.2",
    "node-pty": "^1.0.0",
    "tar": "7.5.16",
    "zod": "^4.1.12",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@electron-toolkit/eslint-config-prettier": "^2.0.0",
    "@electron-toolkit/eslint-config-ts": "^2.0.0",
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@electron/fuses": "^2.1.2",
    "@monaco-editor/react": "^4.7.0",
    "@playwright/test": "^1.57.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/yazl": "^3.3.1",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^3.2.4",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "dockview": "^4.9.0",
    "dotenv": "^17.3.1",
    "electron": "^39.2.4",
    "electron-builder": "26.8.1",
    "electron-playwright-helpers": "^2.0.1",
    "electron-vite": "^5.0.0",
    "eslint": "^9.16.0",
    "eslint-plugin-react": "^7.37.2",
    "hast-util-sanitize": "^5.0.2",
    "js-yaml": "^4.2.0",
    "jsdom": "^25.0.1",
    "lucide-react": "^0.545.0",
    "mermaid": "^11.12.0",
    "monaco-editor": "^0.55.1",
    "patch-package": "^8.0.1",
    "path-browserify": "^1.0.1",
    "prettier": "^3.4.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "rimraf": "^6.1.3",
    "shx": "^0.4.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.46.1",
    "vite": "^6.4.1",
    "vitest": "^3.2.4",
    "yazl": "^3.3.1"
  },
  "overrides": {
    "@electron/rebuild": "3.7.1",
    "chokidar": "3.6.0",
    "lodash": "4.18.1",
    "lodash-es": "4.18.1",
    "dompurify": "^3.4.1"
  }
}
